# API keys and external service credentials
# Copy this file to .env and fill in required values before running the pipeline.
# Never commit .env to version control.

# ── Data sources ──────────────────────────────────────────────────────────────

# Congress.gov API key (https://api.congress.gov/)
CONGRESS_API_KEY=

# CourtListener / PACER API credentials (for federal court dockets)
COURTLISTENER_API_TOKEN=

# News/feed API (structured political news aggregator)
NEWS_API_KEY=

# FRED API key (Federal Reserve Economic Data)
FRED_API_KEY=

# ── Pipeline configuration ─────────────────────────────────────────────────────

# Local directory where raw staged data files are written
STAGING_DIR=data/staging

# Local directory for model artefacts (classifiers, calibrators)
MODEL_DIR=models/artefacts

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
